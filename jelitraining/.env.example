VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=your-supabase-publishable-key
VITE_DEFAULT_PW=ChangeMe123
VITE_COACH_NAME=YourFirstName
VITE_COACH_FULLNAME=Your Full Name
VITE_COACH_INITIALS=YI
VITE_COACH_EMAIL=your@email.com
VITE_COACH_INSTAGRAM=@your_instagram
VITE_COACH_CITY=YourCity
VITE_COACH_TITLE=Your Certification
VITE_PAYMENT_LINK=https://your-payment-link.com

# Feature flags (optional). Set to "true" to enable.
# When false/unset, the feature is fully hidden — zero UI, zero code paths.
VITE_CALENDAR_ENABLED=false

# Token that guards the /api/ical subscription feed.
# The URL itself is the secret (iOS can't send auth headers for subscribed
# calendars), so generate a long random string (e.g. `openssl rand -hex 24`)
# and set the SAME value in Vercel. The token is read both server-side
# (to validate the request) and client-side (to build the URL shown in
# the Réglages page), which is why it uses the VITE_ prefix.
VITE_ICAL_FEED_TOKEN=
